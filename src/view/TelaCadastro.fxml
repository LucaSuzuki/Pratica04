<?xml version="1.0" encoding="UTF-8"?>

<?import javafx.scene.control.*?>
<?import javafx.scene.layout.*?>

<AnchorPane xmlns="http://javafx.com/javafx"
            xmlns:fx="http://javafx.com/fxml"
            fx:controller="gui.TelaCadastro"
            prefWidth="600" prefHeight="500">

    <children>

        <VBox spacing="15" AnchorPane.topAnchor="20" AnchorPane.leftAnchor="20" AnchorPane.rightAnchor="20">

            <Label text="Cadastro de Cliente" style="-fx-font-size: 18px; -fx-font-weight: bold;" />

            <GridPane hgap="10" vgap="10">

                <!-- Nome -->
                <Label text="Nome:" GridPane.rowIndex="0" GridPane.columnIndex="0"/>
                <TextField fx:id="nomeField" GridPane.rowIndex="0" GridPane.columnIndex="1"/>

                <!-- CPF -->
                <Label text="CPF:" GridPane.rowIndex="1" GridPane.columnIndex="0"/>
                <TextField fx:id="cpfField" GridPane.rowIndex="1" GridPane.columnIndex="1"/>

                <!-- Data de Nascimento -->
                <Label text="Data de Nascimento:" GridPane.rowIndex="2" GridPane.columnIndex="0"/>
                <DatePicker fx:id="dataNascimentoField" GridPane.rowIndex="2" GridPane.columnIndex="1"/>

                <!-- Telefone -->
                <Label text="Telefone:" GridPane.rowIndex="3" GridPane.columnIndex="0"/>
                <TextField fx:id="telefoneField" GridPane.rowIndex="3" GridPane.columnIndex="1"/>

                <!-- Endereço -->
                <Label text="Endereço:" GridPane.rowIndex="4" GridPane.columnIndex="0"/>
                <TextField fx:id="enderecoField" GridPane.rowIndex="4" GridPane.columnIndex="1"/>

                <!-- Bairro -->
                <Label text="Bairro:" GridPane.rowIndex="5" GridPane.columnIndex="0"/>
                <TextField fx:id="bairroField" GridPane.rowIndex="5" GridPane.columnIndex="1"/>

                <!-- Cidade -->
                <Label text="Cidade:" GridPane.rowIndex="6" GridPane.columnIndex="0"/>
                <TextField fx:id="cidadeField" GridPane.rowIndex="6" GridPane.columnIndex="1"/>

                <!-- Estado -->
                <Label text="Estado:" GridPane.rowIndex="7" GridPane.columnIndex="0"/>
                <TextField fx:id="estadoField" GridPane.rowIndex="7" GridPane.columnIndex="1"/>

                <!-- CEP -->
                <Label text="CEP:" GridPane.rowIndex="8" GridPane.columnIndex="0"/>
                <TextField fx:id="cepField" GridPane.rowIndex="8" GridPane.columnIndex="1"/>

            </GridPane>

            <!-- Botões -->
            <HBox spacing="10">
                <Button text="Cadastrar" onAction="#cadastrar"/>
                <Button text="Alterar" onAction="#alterar"/>
                <Button text="Consultar" onAction="#consultar"/>
                <Button text="Excluir" onAction="#excluir"/>
            </HBox>

        </VBox>

    </children>
</AnchorPane>